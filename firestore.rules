rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSupervisor() {
      return isAuthenticated() && (
        request.auth.token.role == 'supervisor' || 
        getUserData().role == 'supervisor'
      );
    }

    function isManager() {
      return isAuthenticated() && (
        request.auth.token.role == 'manager' || 
        getUserData().role == 'manager'
      );
    }

    function getManagerBranchId() {
      return getUserData().branchId;
    }

    // Rules for SaaS Companies/Tenants
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (
        isSupervisor() || 
        request.auth.token.companyId == companyId || 
        getUserData().companyId == companyId
      );
      allow write: if isSupervisor();
    }

    // Rules for Showrooms / Physical Branches
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isSupervisor();
    }

    // Rules for Staff / User Credentials
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isSupervisor();
      allow update: if isSupervisor() || (
        isAuthenticated() && 
        request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'branchId', 'companyId'])
      );
      allow delete: if isSupervisor();
    }

    // Zero-Trust context validation rules for Commercial Quotes (Orçamentos)
    match /quotes/{quoteId} {
      
      // A salesperson can view only their own quotes. 
      // A manager can view any quote belonging to salespeople of their branch.
      // A supervisor can view all quotes.
      allow read: if isAuthenticated() && (
        isSupervisor() ||
        (isManager() && resource.data.branchId == getManagerBranchId()) ||
        resource.data.createdBy == request.auth.uid
      );

      // Anyone with valid salesperson/manager access can create a quote to their assigned branch.
      allow create: if isAuthenticated() && (
        isSupervisor() ||
        (isManager() && request.resource.data.branchId == getManagerBranchId()) ||
        request.resource.data.createdBy == request.auth.uid
      );

      // Quote lifecycle: Can only update if owner, or manager of that branch, or supervisor.
      allow update: if isAuthenticated() && (
        isSupervisor() ||
        (isManager() && resource.data.branchId == getManagerBranchId()) ||
        resource.data.createdBy == request.auth.uid
      );

      // Deleting a financial/commercial record is restricted to Supervisors only for absolute consistency.
      allow delete: if isSupervisor();
    }

    // Lock down any other unmapped sub-collection by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
